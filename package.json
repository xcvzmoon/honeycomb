{
  "name": "honeycomb",
  "description": "My nuxt starter template",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "check": "vp check",
    "fmt": "vp fmt && vp fmt --check",
    "lint": "vp lint",
    "typecheck": "nuxt typecheck",
    "prepare": "vp config",
    "test": "vp test",
    "test:watch": "vp test --watch",
    "test:coverage": "vp test --coverage",
    "test:unit": "vp test --project unit",
    "test:nuxt": "vp test --project nuxt",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "release:patch": "changelogen --patch --release && git push --follow-tags",
    "release:minor": "changelogen --minor --release && git push --follow-tags",
    "release:major": "changelogen --major --release && git push --follow-tags",
    "release:dry": "changelogen --dry"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.114",
    "@nuxt/hints": "1.1.3",
    "@nuxt/ui": "4.9.0",
    "@vueuse/core": "^14.3.0",
    "@vueuse/nuxt": "^14.3.0",
    "nuxt": "^4.4.8",
    "vue": "^3.5.38",
    "vue-router": "^5.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nuxt/test-utils": "^4.0.3",
    "@playwright/test": "^1.61.1",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/test-utils": "^2.4.11",
    "changelogen": "^0.6.2",
    "happy-dom": "^20.10.6",
    "playwright-core": "^1.61.1",
    "typescript": "^6.0.3",
    "vite-plus": "catalog:",
    "vitest": "catalog:",
    "vue-tsc": "^3.3.5"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
