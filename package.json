{
  "name": "honeycomb",
  "description": "My nuxt starter template",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "check": "vp check",
    "fmt": "run-p nuxt:fmt tauri:fmt",
    "lint": "run-p nuxt:lint tauri:lint",
    "prepare": "vp config",
    "test": "run-p nuxt:test tauri:test",
    "dev": "vpr tauri:dev",
    "build": "run-p nuxt:build tauri:build",
    "nuxt:build": "nuxt build",
    "nuxt:dev": "nuxt dev",
    "nuxt:generate": "nuxt generate",
    "nuxt:preview": "nuxt preview",
    "nuxt:postinstall": "nuxt prepare",
    "nuxt:typecheck": "nuxt typecheck",
    "nuxt:fmt": "vp fmt && vp fmt --check",
    "nuxt:lint": "vp lint",
    "nuxt:test": "vp test",
    "nuxt:test:watch": "vp test --watch",
    "nuxt:test:coverage": "vp test --coverage",
    "nuxt:test:unit": "vp test --project unit",
    "nuxt:test:nuxt": "vp test --project nuxt",
    "nuxt:test:e2e": "playwright test",
    "nuxt:test:e2e:ui": "playwright test --ui",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:fmt": "cd src-tauri && cargo fmt && cargo fmt --check",
    "tauri:lint": "cd src-tauri && cargo clippy -- -D warnings",
    "tauri:test": "cd src-tauri && cargo test",
    "release:patch": "changelogen --patch --bump && vpr release:finish",
    "release:minor": "changelogen --minor --bump && vpr release:finish",
    "release:major": "changelogen --major --bump && vpr release:finish",
    "release:dry": "changelogen --dry",
    "release:finish": "run-s sync:tauri-version release:commit release:push",
    "release:commit": "node scripts/create-release-commit.ts",
    "release:push": "git push --follow-tags",
    "sync:tauri-version": "node scripts/sync-tauri-version.ts"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.114",
    "@nuxt/hints": "1.1.3",
    "@nuxt/ui": "4.9.0",
    "@vueuse/core": "^14.3.0",
    "@vueuse/nuxt": "^14.3.0",
    "nuxt": "^4.4.8",
    "vue": "^3.5.38",
    "vue-router": "^5.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nuxt/test-utils": "^4.0.3",
    "@playwright/test": "^1.61.1",
    "@tauri-apps/cli": "^2.11.3",
    "@types/node": "^26.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/test-utils": "^2.4.11",
    "changelogen": "^0.6.2",
    "happy-dom": "^20.10.6",
    "npm-run-all2": "^9.0.2",
    "playwright-core": "^1.61.1",
    "typescript": "^6.0.3",
    "vite-plus": "catalog:",
    "vitest": "catalog:",
    "vue-tsc": "^3.3.5"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
